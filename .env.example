# Telegram
TELEGRAM_BOT_TOKEN=123456:your-bot-token
WC3_CHAT_ID=-1001234567890

# Liquipedia API key: either set it here, or place it in ./.liquipedia.token
# (mounted into the container at /app/.liquipedia.token via LIQUIPEDIA_TOKEN_FILE).
# LIQUIPEDIA_API_KEY=your-key

# SOCKS5 proxy used to reach Liquipedia (not directly routable here).
LIQUIPEDIA_PROXY=socks5://127.0.0.1:18237

# Tuning
TIER_MAX=2                 # tiers 1..N count as "top" (1=S, 2=A)
UPDATE_INTERVAL_SECONDS=180
POST_BEFORE_MINUTES=30
